# --- Database ---
DATABASE_URL=postgresql+asyncpg://monitor:password@localhost:5432/mantle_monitor

# --- API Keys ---
DUNE_API_KEY=
COINGECKO_API_KEY=

# --- Dune Queries ---
DUNE_STABLECOIN_VOLUME_QUERY_ID=0

# --- Feature Flags ---
AI_ENRICHMENT_ENABLED=false
LARK_DELIVERY_ENABLED=false
LARK_BOT_ENABLED=false
BOT_EXTERNAL_ACTIONS_ENABLED=false

# --- Lark ---
LARK_APP_ID=
LARK_APP_SECRET=
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=
LARK_ENVIRONMENT=dev
LARK_ALERT_CHAT_ID_DEV=
LARK_ALERT_CHAT_ID_PROD=
LARK_SUMMARY_CHAT_ID_DEV=
LARK_SUMMARY_CHAT_ID_PROD=

# --- LLM ---
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
LLM_APP_NAME=mantle-eco-monitor
LLM_APP_URL=https://github.com/Whisker17/mantle-eco-monitor
LLM_TIMEOUT_SECONDS=30

# --- Scheduler ---
SCHEDULER_ENABLED=true
# SCHEDULER_PROFILE=prod
# SCHEDULER_PROFILE=dev_live
# SCHEDULER_CONFIG_PATH=config/scheduler.toml
# Local smoke check:
# ./scripts/dev_live_check.sh full
# ./scripts/dev_live_check.sh down

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql+asyncpg://monitor:password@localhost:5432/mantle_monitor

# --- API Keys ---
DUNE_API_KEY=
COINGECKO_API_KEY=

# --- Dune Queries ---
DUNE_STABLECOIN_VOLUME_QUERY_ID=0

# --- Feature Flags ---
AI_ENRICHMENT_ENABLED=false
LARK_DELIVERY_ENABLED=false

# --- Scheduler ---
SCHEDULER_ENABLED=true
# SCHEDULER_PROFILE=prod
# SCHEDULER_PROFILE=dev_live
# SCHEDULER_CONFIG_PATH=config/scheduler.toml

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
